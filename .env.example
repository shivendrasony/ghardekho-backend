# ── GharDekho Backend — Environment Variables ──────────────────────────────
# Copy this to .env:  cp .env.example .env

SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────
# SQLite is used by default (great for development, no setup needed).
# To switch to PostgreSQL for production, set USE_SQLITE=False
# and fill in the PostgreSQL credentials below.
USE_SQLITE=True

# PostgreSQL (only needed when USE_SQLITE=False)
DB_NAME=ghardekho_db
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432

# ── CORS — React frontend URL ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
